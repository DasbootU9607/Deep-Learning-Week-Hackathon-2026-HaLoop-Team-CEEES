{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch AI Gov Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/ide-plugin",
        "${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/ide-plugin/dist/**/*.js"
      ],
      "preLaunchTask": "build-ide-plugin"
    }
  ]
}

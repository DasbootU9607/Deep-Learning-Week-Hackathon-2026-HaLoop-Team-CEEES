BACKEND_MODE=prod
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/guardian
REDIS_URL=redis://localhost:6379
PROD_BOOTSTRAP_SAMPLE_DATA=true

PLANNER_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_WEBHOOK_SECRET=
OPENAI_MAX_ATTEMPTS=4
OPENAI_BACKGROUND_MAX_POLLS=40
OPENAI_FALLBACK_TO_HEURISTIC=true

PLAN_QUEUE_ATTEMPTS=4
PLAN_QUEUE_BACKOFF_MS=500
PLAN_QUEUE_CONCURRENCY=3

EVAL_GATE_MIN_SCHEMA_VALID=0.98
EVAL_GATE_MIN_HIGH_RISK_RECALL=0.75
EVAL_GATE_MIN_APPROVAL_RECALL=0.75
